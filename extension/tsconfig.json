{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"outDir": "output",
		"lib": [
			"ES2020",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": "source",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"exclude": [
		"node_modules"
	]
}
